global_defs {
}

vrrp_instance VI_1 {
  state ${MASTER_OR_BACKUP_STATE}
  interface ${KEEPALIVED_INTERFACE}
  virtual_router_id 51
  priority ${KEEPALIVED_PRIORITY}
  advert_int 3
  unicast_src_ip ${PRIMARY_IP}
  unicast_peer { ${SECONDARY_IP} }


  authentication {
    auth_type PASS
    auth_pass ${KEEPALIVED_AUTH_PASS}
  }

  virtual_ipaddress {
    ${KEEPALIVED_VIRTUAL_IP}/24
  }

  notify /etc/keepalived/notify.sh
  notify_stop "/etc/keepalived/notify.sh INSTANCE VI_1 FAULT"
}