---
import { stack } from '../data/stack';
---
<section id="stack">
  <h2 class="section-heading">Stack</h2>
  {stack.map((group) => (
    <div style="margin-bottom:1.25rem;">
      <p class="fig-label" style="margin-bottom:0.25rem;">{group.category}</p>
      <p style="margin:0;">{group.items.join(' · ')}</p>
    </div>
  ))}
</section>
